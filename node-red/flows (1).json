    {
        "id": "9160073d64216301",
        "type": "function",
        "z": "8a34ae09c3dd8a98",
        "name": "alerte",
        "func": "// Initialisation des variables\nlet timer = context.get('timer') || 60;\nlet active = context.get('active') || false;\nlet lastData = context.get('lastData') || { temp: 0, press: 0, vib: 0 };\nlet typeMsg = context.get('typeMsg') || \"\";\nlet moteurSource = context.get('moteurSource') || \"\";\n\n// Gestion du RESET\nif (msg.topic === \"reset\") {\n    timer = 60; active = false; typeMsg = \"\";\n    context.set('timer', timer); context.set('active', active);\n    return [{ payload: { reset: true } }, { payload: 0 }, null];\n}\n\nif (msg.topic === \"tick\") {\n    if (active && timer > 0) timer--;\n} else {\n    let currentMoteur = msg.topic.includes(\"moteur1\") ? \"ENG 1\" : \"ENG 2\";\n    lastData = msg.payload;\n    let danger = false;\n    let currentType = \"\";\n\n    // Diagnostic des problèmes (Surchauffe, Basse Pression, Vibrations)\n    if (lastData.temp > 850) { currentType = \"SURCHAUFFE\"; danger = true; }\n    else if (lastData.press < 30) { currentType = \"BASSE PRESSION\"; danger = true; }\n    else if (lastData.vib > 40) { currentType = \"VIBRATIONS\"; danger = true; }\n\n    if (danger) { active = true; moteurSource = currentMoteur; typeMsg = currentType; }\n    else if (moteurSource === currentMoteur) { active = false; timer = 60; typeMsg = \"\"; }\n    context.set('lastData', lastData);\n}\n\n// --- LOGIQUE DE CONSOMMATION RÉALISTE (FUEL FLOW) ---\nlet fuelFixed = 0;\nif (lastData.temp > 100) { \n    // 1. La température (EGT) augmente la consommation de base\n    let baseConsumption = lastData.temp * 0.08; \n    \n    // 2. Les vibrations augmentent la résistance et donc la consommation\n    let vibrationImpact = lastData.vib * 0.5; \n    \n    // 3. Basse pression = Perte d'efficacité = Augmentation de la consommation pour compenser\n    let pressureFactor = 1.0;\n    if (lastData.press < 40) {\n        pressureFactor = 1.25; // Augmentation de 25% si la pression est basse\n    }\n\n    // Calcul final réaliste\n    let totalFlow = (baseConsumption + vibrationImpact) * pressureFactor + (Math.random() * 2);\n    fuelFixed = parseFloat(totalFlow.toFixed(1));\n}\n\ncontext.set('timer', timer); \ncontext.set('active', active);\ncontext.set('typeMsg', typeMsg); \ncontext.set('moteurSource', moteurSource);\n\n// --- SORTIES (OUTPUTS) ---\n// 1: Interface Template (Avion)\nlet msgTemplate = { \n    payload: { \n        ...lastData, \n        timer: timer, \n        isCritical: active, \n        msgLabel: typeMsg, \n        moteur: moteurSource || (msg.topic.includes(\"moteur1\") ? \"ENG 1\" : \"ENG 2\") \n    } \n};\n\n// 2: Jauge Fuel Flow\nlet msgGauge = { payload: fuelFixed };\n\n// 3: Notification d'alerte\nlet msgNotify = (active && timer % 20 === 0) ? { payload: \"⚠️ ATTENTION: \" + moteurSource + \" \" + typeMsg } : null;\n\nreturn [msgTemplate, msgGauge, msgNotify];",
        "outputs": 3,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
