    {
        "id": "edd4d1d9b383e88c",
        "type": "ui_template",
        "z": "8a34ae09c3dd8a98",
        "group": "6ca54ea811e100e2",
        "name": "",
        "order": 1,
        "width": "5",
        "height": "7",
        "format": "<div\n    style=\"background: #0b0b0b; padding: 15px; border-radius: 15px; text-align: center; color: white; border: 1px solid #333;\">\n    <h5 style=\"margin:0 0 10px 0; color: #888; letter-spacing: 1px;\">SYSTEM MONITOR EICAS</h5>\n\n    <svg width=\"200\" height=\"180\" viewBox=\"0 0 120 120\">\n        <path d=\"M60 10 Q66 10 66 30 L66 95 Q66 105 60 105 Q54 105 54 95 L54 30 Q54 10 60 10 Z\" fill=\"#cfd8dc\" />\n        <path d=\"M54 45 L5 75 L5 82 L54 65 Z\" fill=\"#90a4ae\" />\n        <path d=\"M66 45 L115 75 L115 82 L66 65 Z\" fill=\"#90a4ae\" />\n        <path d=\"M54 92 L35 102 L35 105 L54 100 Z\" fill=\"#90a4ae\" />\n        <path d=\"M66 92 L85 102 L85 105 L66 100 Z\" fill=\"#90a4ae\" />\n        <rect id=\"engine1\" x=\"22\" y=\"62\" width=\"16\" height=\"22\" rx=\"8\" fill=\"#2ecc71\" stroke=\"#1a1a1a\" />\n        <rect id=\"engine2\" x=\"82\" y=\"62\" width=\"16\" height=\"22\" rx=\"8\" fill=\"#2ecc71\" stroke=\"#1a1a1a\" />\n    </svg>\n\n    <div\n        style=\"background: rgba(0,0,0,0.6); padding: 10px; border-radius: 8px; font-size: 11px; border: 1px solid #222; margin-top: 10px;\">\n        <div id=\"d1\" style=\"color: #2ecc71; text-align: left; margin-bottom: 6px;\">\n            <b style=\"color:#eee\">ENG 1</b> <span style=\"float:right\"><span id=\"t1\">--</span>°C |\n            <span id=\"p1\">--</span> PSI | <span id=\"v1\">--</span> mm/s</span>\n        </div>\n        <div id=\"d2\" style=\"color: #2ecc71; text-align: left; border-top: 1px solid #222; padding-top: 6px;\">\n            <b style=\"color:#eee\">ENG 2</b> <span style=\"float:right\"><span id=\"t2\">--</span>°C |\n            <span id=\"p2\">--</span> PSI | <span id=\"v2\">--</span> mm/s</span>\n        </div>\n    </div>\n\n    <div id=\"banner\"\n        style=\"display:none; margin-top: 10px; padding: 12px; background: #d32f2f; font-weight: bold; border-radius: 6px; border: 2px solid white; animation: slideIn 0.3s;\">\n        ⚠️ <span id=\"alert-txt\">--</span> : <span id=\"timer-txt\">60</span>s\n    </div>\n</div>\n\n<style>\n    .blink-red {\n        animation: danger-pulse 0.6s infinite;\n    }\n\n    @keyframes danger-pulse {\n        0% {\n            fill: #f44336;\n        }\n\n        50% {\n            fill: #212121;\n        }\n\n        100% {\n            fill: #f44336;\n        }\n    }\n\n    @keyframes slideIn {\n        from {\n            transform: translateY(10px);\n            opacity: 0;\n        }\n\n        to {\n            transform: translateY(0);\n            opacity: 1;\n        }\n    }\n</style>\n\n<script>\n    (function(scope) {\n    scope.$watch('msg', function(msg) {\n        if (!msg || !msg.payload) return;\n        let d = msg.payload;\n        let b = document.getElementById(\"banner\");\n        let e1 = document.getElementById(\"engine1\");\n        let e2 = document.getElementById(\"engine2\");\n\n        if (d.reset) {\n            b.style.display=\"none\"; e1.className.baseVal=\"\"; e2.className.baseVal=\"\";\n            e1.setAttribute(\"fill\",\"#2ecc71\"); e2.setAttribute(\"fill\",\"#2ecc71\");\n            return;\n        }\n\n        if (d.isCritical) {\n            b.style.display=\"block\"; document.getElementById(\"timer-txt\").innerText = d.timer;\n            document.getElementById(\"alert-txt\").innerText = d.moteur + \" \" + d.msgLabel;\n            if (d.moteur === \"ENG 1\") { e1.className.baseVal=\"blink-red\"; e2.className.baseVal=\"\"; e2.setAttribute(\"fill\",\"#2ecc71\"); }\n            else { e2.className.baseVal=\"blink-red\"; e1.className.baseVal=\"\"; e1.setAttribute(\"fill\",\"#2ecc71\"); }\n        } else {\n            b.style.display=\"none\"; e1.className.baseVal=\"\"; e2.className.baseVal=\"\";\n            e1.setAttribute(\"fill\",\"#2ecc71\"); e2.setAttribute(\"fill\",\"#2ecc71\");\n        }\n\n        let s = d.moteur.includes(\"1\") ? \"1\" : \"2\";\n        if(d.temp) document.getElementById(\"t\"+s).innerText = Math.round(d.temp);\n        if(d.press) document.getElementById(\"p\"+s).innerText = Math.round(d.press);\n        if(d.vib) document.getElementById(\"v\"+s).innerText = Number(d.vib).toFixed(1);\n    });\n})(scope);\n</script>",
