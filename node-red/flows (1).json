    {
        "id": "0f104d8244ab2f05",
        "type": "function",
        "z": "8a34ae09c3dd8a98",
        "name": "curve",
        "func": "// 1. Vérification : On s'assure que le payload est bien un objet JSON\nif (typeof msg.payload !== 'object') {\n    return null; \n}\n\n// 2. Identification du moteur à partir du Topic MQTT\n// Si le topic contient \"moteur1\", on utilise le préfixe \"ENG 1\", sinon \"ENG 2\"\nlet enginePrefix = msg.topic.includes(\"moteur1\") ? \"ENG 1\" : \"ENG 2\";\n\n// 3. Préparation et envoi des messages pour le graphique (6 courbes possibles)\n\n// Envoi de la Température\nnode.send({\n    topic: enginePrefix + \" Température\",\n    payload: msg.payload.temp\n});\n\n// Envoi de la Pression\nnode.send({\n    topic: enginePrefix + \" Pression\",\n    payload: msg.payload.press\n});\n\n// Envoi des Vibrations\nnode.send({\n    topic: enginePrefix + \" Vibration\",\n    payload: msg.payload.vib\n});\n\n// On retourne null car les messages sont déjà envoyés via node.send()\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 530,
        "y": 360,
        "wires": [
            [
                "e9236bf9c87fbf6a",
                "66486aac2da1a985"
            ]
        ]
    },
